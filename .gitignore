# Visual Studio 2015 user specific files
.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Binary Files
Binaries/*
Plugins/*/Binaries/*

# Builds
Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!NornalTown_Game/Build/*/
NornalTown_Game/Build/*/**
!NornalTown_Game/Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!NornalTown_Game/Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
NornalTown_Game/Saved/*

# Compiled source files for the engine to use
NornalTown_Game/Intermediate/*
NornalTown_Game/Plugins/*/Intermediate/*

# Cache files for the editor to use
NornalTown_Game/DerivedDataCache/*
NornalTown_Game/.idea
NornalTown_Game/Plugins/Developer
NornalTown_Game/Builds
NornalTown_Game/Config/steamvr_ue_editor_app.json
NornalTown_Game/Config/SteamVRBindings
NornalTown_Game/Platforms/HoloLens/Config/HoloLensEngine.ini
NornalTown_Game/.vsconfig